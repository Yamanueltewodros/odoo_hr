<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sfk_equipment_incident_view_list" model="ir.ui.view">
            <field name="name">sfk.equipment.incident.list</field>
            <field name="model">sfk.equipment.incident</field>
            <field name="arch" type="xml">
                <list string="Equipment Incidents"
                      decoration-danger="incident_type == 'theft'"
                      decoration-warning="incident_type == 'damage'"
                      decoration-info="incident_type == 'maintenance'">
                    <field name="name"/>
                    <field name="incident_date"/>
                    <field name="incident_type" widget="badge"
                           decoration-danger="incident_type in ('loss','theft')"
                           decoration-warning="incident_type == 'damage'"
                           decoration-info="incident_type == 'maintenance'"/>
                    <field name="equipment_category"/>
                    <field name="equipment_description"/>
                    <field name="quantity"/>
                    <field name="program_id"/>
                    <field name="reported_by"/>
                    <field name="escalate_to_head" optional="show"/>
                    <field name="state" widget="badge"
                           decoration-danger="state == 'reported'"
                           decoration-warning="state == 'investigating'"
                           decoration-success="state in ('resolved','closed')"/>
                </list>
            </field>
        </record>

        <record id="sfk_equipment_incident_view_form" model="ir.ui.view">
            <field name="name">sfk.equipment.incident.form</field>
            <field name="model">sfk.equipment.incident</field>
            <field name="arch" type="xml">
                <form string="Equipment Incident">
                    <header>
                        <button name="action_investigate" string="Investigate"
                                type="object" class="btn-primary"
                                invisible="state != 'reported'"
                                groups="sfk_operation_standard.group_sfk_standards_officer"/>
                        <button name="action_resolve" string="Resolve"
                                type="object" class="btn-success"
                                invisible="state != 'investigating'"
                                groups="sfk_operation_standard.group_sfk_standards_officer"/>
                        <button name="action_close" string="Close"
                                type="object"
                                invisible="state != 'resolved'"
                                groups="sfk_operation_standard.group_sfk_head_of_standards"/>
                        <button name="action_escalate" string="Escalate"
                                type="object"
                                invisible="state in ('resolved','closed') or escalate_to_head"
                                groups="sfk_operation_standard.group_sfk_standards_officer"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="reported,investigating,resolved,closed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group string="Incident Details">
                                <field name="incident_date"/>
                                <field name="incident_type"/>
                                <field name="equipment_category"/>
                                <field name="equipment_description"
                                       placeholder="Serial No., description…"/>
                                <field name="quantity"/>
                                <field name="estimated_value"/>
                            </group>
                            <group string="Context">
                                <field name="program_id"/>
                                <field name="session_id"/>
                                <field name="company_id"/>
                                <field name="reported_by" readonly="1"/>
                                <field name="responsible_staff_id"/>
                                <field name="escalate_to_head"/>
                            </group>
                        </group>
                        <group string="Description">
                            <field name="description" nolabel="1"
                                   placeholder="Describe what happened…"/>
                        </group>
                        <group string="Resolution" invisible="state == 'reported'">
                            <field name="action_taken"
                                   placeholder="Describe corrective actions taken…"/>
                            <field name="resolved_date"/>
                            <field name="replacement_cost"/>
                            <field name="cost_recovered"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_sfk_equipment_incident" model="ir.actions.act_window">
            <field name="name">Equipment Incidents</field>
            <field name="res_model">sfk.equipment.incident</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_sfk_equipment_incident_open" model="ir.actions.act_window">
            <field name="name">Open Incidents</field>
            <field name="res_model">sfk.equipment.incident</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', 'in', ('reported', 'investigating'))]</field>
        </record>
    </data>
</odoo>
