<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sfk_term_view_list" model="ir.ui.view">
            <field name="name">sfk.term.list</field>
            <field name="model">sfk.term</field>
            <field name="arch" type="xml">
                <list string="Terms">
                    <field name="name"/>
                    <field name="program_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="sfk_term_view_form" model="ir.ui.view">
            <field name="name">sfk.term.form</field>
            <field name="model">sfk.term</field>
            <field name="arch" type="xml">
                <form string="Term">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="program_id"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="start_date"/>
                                <field name="end_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Grade / Course Mapping">
                                <field name="term_course_ids">
                                    <list editable="bottom">
                                        <field name="grade"/>
                                        <field name="course_id"/>
                                    </list>
                                </field>
                                <p class="text-muted">
                                    Map each grade to the course taught this term.
                                    Permanent schedules will auto-derive the course from this table.
                                </p>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_sfk_term" model="ir.actions.act_window">
            <field name="name">Terms</field>
            <field name="res_model">sfk.term</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
