<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ── All Sessions ──────────────────────────────────────────────── -->
        <record id="action_sfk_program_session" model="ir.actions.act_window">
            <field name="name">All Sessions</field>
            <field name="res_model">sfk.session</field>
            <field name="view_mode">list,form,calendar</field>
        </record>

        <!-- ── My Today's Sessions ───────────────────────────────────────── -->
        <record id="action_sfk_today_session" model="ir.actions.act_window">
            <field name="name">My Today's Sessions</field>
            <field name="res_model">sfk.session</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[
                ('start_datetime', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')),
                ('start_datetime', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59')),
                '|',
                ('lead_instructor_id.user_id', '=', uid),
                ('assistant_instructor_id.user_id', '=', uid)
            ]</field>
        </record>

        <!-- ── List View ─────────────────────────────────────────────────── -->
        <record id="sfk_session_view_list" model="ir.ui.view">
            <field name="name">sfk.session.list</field>
            <field name="model">sfk.session</field>
            <field name="arch" type="xml">
                <list string="Sessions"
                      decoration-info="state == 'draft'"
                      decoration-success="state == 'done'"
                      decoration-danger="state == 'cancelled'">
                    <field name="name"/>
                    <field name="program_id"/>
                    <field name="term_id"/>
                    <field name="course_id"/>
                    <field name="grade" optional="show"/>
                    <field name="start_datetime"/>
                    <field name="end_datetime"/>
                    <field name="duration_hours" widget="float_time"
                           optional="hide"/>
                    <field name="lead_instructor_id"/>
                    <field name="room_id" optional="show"/>
                    <field name="attendance_count" optional="show"
                           string="Enrolled"/>
                    <field name="present_count" optional="show"
                           string="Present"/>
                    <field name="state" widget="badge"
                           decoration-info="state == 'draft'"
                           decoration-success="state == 'done'"
                           decoration-warning="state == 'confirmed'"
                           decoration-danger="state == 'cancelled'"/>
                </list>
            </field>
        </record>

        <!-- ── Calendar View ─────────────────────────────────────────────── -->
        <record id="sfk_session_view_calendar" model="ir.ui.view">
            <field name="name">sfk.session.calendar</field>
            <field name="model">sfk.session</field>
            <field name="arch" type="xml">
                <calendar string="Sessions"
                          date_start="start_datetime"
                          date_stop="end_datetime"
                          color="program_id">
                    <field name="name"/>
                    <field name="lead_instructor_id"/>
                    <field name="state"/>
                </calendar>
            </field>
        </record>

        <!-- ── Form View ─────────────────────────────────────────────────── -->
        <record id="sfk_session_view_form" model="ir.ui.view">
            <field name="name">sfk.session.form</field>
            <field name="model">sfk.session</field>
            <field name="arch" type="xml">
                <form string="Session">
                    <header>
                        <button name="action_confirm" string="Confirm"
                                type="object" class="btn-primary"
                                invisible="state != 'draft'"
                                groups="sfk_operation.group_sfk_coordinator"/>
                        <button name="action_done" string="Mark as Done"
                                type="object" class="btn-primary"
                                invisible="state != 'confirmed'"
                                groups="sfk_operation.group_sfk_coordinator"/>
                        <button name="action_cancel" string="Cancel"
                                type="object"
                                invisible="state in ['done', 'cancelled']"
                                groups="sfk_operation.group_sfk_coordinator"/>
                        <button name="action_reset_to_draft" string="Reset to Draft"
                                type="object"
                                invisible="state != 'cancelled'"
                                groups="sfk_operation.group_sfk_manager"/>
                        <button name="action_load_students"
                                string="Reload Students"
                                type="object"
                                invisible="state != 'confirmed' or program_type != 'center'"
                                groups="sfk_operation.group_sfk_coordinator"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,confirmed,done"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" icon="fa-check-circle"
                                    type="object" name="action_load_students"
                                    invisible="program_type != 'center' or state == 'done'">
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_value">
                                        <field name="attendance_count"/>
                                    </span>
                                    <span class="o_stat_text">Enrolled</span>
                                </div>
                            </button>
                            <div class="oe_stat_button" icon="fa-users"
                                 invisible="program_type != 'center'">
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_value">
                                        <field name="present_count"/>
                                        / <field name="attendance_count"/>
                                    </span>
                                    <span class="o_stat_text">Present</span>
                                </div>
                            </div>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Session Details">
                                <field name="program_id"/>
                                <field name="program_type" invisible="1"/>
                                <field name="term_id"
                                       domain="[('program_id', '=', program_id)]"/>
                                <field name="course_id"/>
                                <field name="grade"
                                       invisible="program_type != 'school'"/>
                                <field name="center_id"/>
                            </group>
                            <group string="Scheduling">
                                <field name="start_datetime"/>
                                <field name="end_datetime"/>
                                <field name="duration_hours" widget="float_time"
                                       readonly="1"/>
                                <field name="room_id"
                                       domain="[('company_id', '=', center_id)]"/>
                            </group>
                        </group>

                        <group>
                            <group string="Execution">
                                <field name="execution_state" widget="radio"
                                       options="{'horizontal': true}"/>
                                <field name="reason_not_conducted"
                                       invisible="execution_state == 'conducted'"
                                       required="execution_state != 'conducted'"/>
                                <field name="school_student_count"
                                       invisible="program_type != 'school'"/>
                            </group>
                            <group string="Instructor Availability">
                                <label for="lead_instructor_id"
                                       string="Lead Instructor"/>
                                <div class="o_row">
                                    <field name="lead_instructor_id" readonly="1"/>
                                    <field name="lead_instructor_status"
                                           class="oe_inline"/>
                                    <field name="lead_substitute_id"
                                           invisible="lead_instructor_status != 'substituted'"
                                           required="lead_instructor_status == 'substituted'"
                                           placeholder="Substitute"/>
                                </div>

                                <label for="assistant_instructor_id"
                                       string="Assistant"
                                       invisible="not assistant_instructor_id"/>
                                <div class="o_row"
                                     invisible="not assistant_instructor_id">
                                    <field name="assistant_instructor_id"
                                           readonly="1"/>
                                    <field name="assistant_instructor_status"
                                           class="oe_inline"/>
                                    <field name="assistant_substitute_id"
                                           invisible="assistant_instructor_status != 'substituted'"
                                           required="assistant_instructor_status == 'substituted'"
                                           placeholder="Substitute"/>
                                </div>
                            </group>
                        </group>

                        <notebook>
                            <page string="Student Attendance"
                                  invisible="program_type == 'school'">
                                <field name="attendance_ids">
                                    <list editable="bottom"
                                          decoration-success="status == 'present'"
                                          decoration-danger="status == 'absent'"
                                          decoration-warning="status == 'late'">
                                        <field name="student_id" readonly="1"/>
                                        <field name="status" widget="radio"
                                               options="{'horizontal': true}"/>
                                        <field name="notes"
                                               placeholder="Reason for late/absent…"/>
                                        <field name="checked_by"
                                               column_invisible="True"/>
                                        <field name="checked_date"
                                               column_invisible="True"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
    </data>
</odoo>
