<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_sfk_inventory_location_responsible" model="res.groups">
            <field name="name">Stock Location Responsible</field>
            <field name="category_id" ref="base.module_category_operations"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can confirm dispatch/receipt and view stock for assigned internal locations only.</field>
        </record>

        <record id="group_sfk_inventory_supervisor" model="res.groups">
            <field name="name">Inventory Supervisor</field>
            <field name="category_id" ref="base.module_category_operations"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can oversee inventory movements for assigned programs/locations.</field>
        </record>
    </data>
</odoo>
