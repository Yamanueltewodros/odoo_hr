<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_sfk_sale_discount_program_multi_company" model="ir.rule">
        <field name="name">Discount Programs: multi-company</field>
        <field name="model_id" ref="model_sfk_sale_discount_program"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman')), (4, ref('sales_team.group_sale_salesman_all_leads')), (4, ref('sales_team.group_sale_manager'))]"/>
    </record>
</odoo>
