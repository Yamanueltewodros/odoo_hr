<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sfk_room_view_list" model="ir.ui.view">
            <field name="name">sfk.room.list</field>
            <field name="model">sfk.room</field>
            <field name="arch" type="xml">
                <list string="Rooms">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="capacity"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="sfk_room_view_form" model="ir.ui.view">
            <field name="name">sfk.room.form</field>
            <field name="model">sfk.room</field>
            <field name="arch" type="xml">
                <form string="Room">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                            <field name="capacity"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_sfk_room" model="ir.actions.act_window">
            <field name="name">Rooms</field>
            <field name="res_model">sfk.room</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
